{
  "mcpServers": {
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/"
    },
    "sentry": {
      "type": "http",
      "url": "https://mcp.sentry.dev/mcp"
    },
    "firebase-firestore": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "mcp-firestore"],
      "env": {
        "SERVICE_ACCOUNT_KEY_PATH": "${GOOGLE_APPLICATION_CREDENTIALS}",
        "FIRESTORE_PROJECT_ID": "${FIREBASE_PROJECT_ID}"
      }
    },
    "postgres": {
      "type": "stdio",
      "command": "npx",
      "args": ["-y", "@bytebase/dbhub", "--transport", "stdio"],
      "env": {
        "DB_URL": "${DATABASE_URL}"
      }
    }
  }
}
