<% } -%>
<% } -%>
skills:
<% if (ctx.skills.active.length === 0) { -%>
  []
<% } else { -%>
<% for (const s of ctx.skills.active) { -%>
  - <%= s %>
<% } -%>
<% } -%>
agents:
<% if (ctx.agents.active.length === 0) { -%>
  []
<% } else { -%>
<% for (const a of ctx.agents.active) { -%>
  - <%= a %>
<% } -%>
<% } -%>
rules:
<% const rules = ctx.manifest.rules?.active ?? []; if (rules.length === 0) { -%>
  []
<% } else { -%>
<% for (const r of rules) { -%>
  - <%= r %>
<% } -%>
<% } -%>
