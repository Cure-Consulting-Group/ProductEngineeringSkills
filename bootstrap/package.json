{
  "name": "@cure-consulting-group/claude-bootstrap",
  "version": "0.1.0",
  "description": "Bootstraps Cure's Claude development infrastructure into any project. Idempotent, manifest-driven, version-pinned.",
  "type": "module",
  "exports": {
    ".": "./src/index.mjs",
    "./manifest": "./src/manifest/index.mjs",
    "./blocks": "./src/blocks/index.mjs",
    "./schema": "./schemas/claude-manifest.v1.json"
  },
  "bin": {
    "claude-bootstrap": "./bin/claude-bootstrap.mjs"
  },
  "files": [
    "bin/",
    "src/",
    "schemas/",
    "templates/"
  ],
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test test/*.test.mjs"
  },
  "dependencies": {
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "ejs": "^3.1.10"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Cure-Consulting-Group/ProductEngineeringSkills.git",
    "directory": "bootstrap"
  },
  "license": "MIT"
}
